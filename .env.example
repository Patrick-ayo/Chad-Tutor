# Frontend (Vite)
# Required: Clerk publishable key for browser auth.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Optional: API base URL if you deploy frontend and backend on different origins.
# If omitted in local development, Vite proxy in vite.config.ts handles /api.
# VITE_API_BASE_URL=https://api.your-domain.com
