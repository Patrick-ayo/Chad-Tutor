# Server
PORT=3001
NODE_ENV=development

# Clerk - Get these from https://dashboard.clerk.com
CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# PostgreSQL Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/chad_tutor?schema=public"

# Redis (optional - for L1 cache, enable when needed)
# REDIS_URL="redis://localhost:6379"

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5174

# Exam/Subject API Key
EXAM_API_KEY=your-exam-api-key

# Cache Settings
CACHE_EXPIRY_HOURS=168

# YouTube Data API v3 (required for video discovery)
# Get yours from: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=your_youtube_api_key_here

# Mr Chad chatbot Bytez configuration (unique key names)
MR_CHAD_CHATBOT_BYTEZ_API_KEY=your-free-key
MR_CHAD_CHATBOT_MODEL=Qwen/Qwen3-8B

# Optional Gemini configuration
# If set, backend will try Gemini first and then fall back to Bytez on errors.
MR_CHAD_CHATBOT_GEMINI_API_KEY=
# Recommended: gemini-2.0-flash (avoid deprecated model ids like gemini-1.5-pro)
MR_CHAD_CHATBOT_GEMINI_MODEL=gemini-2.0-flash
# Optional comma-separated fallback candidates
# GEMINI_MODEL_CANDIDATES=gemini-2.0-flash,gemini-1.5-flash-latest
